// Key bindings for VSCode auf dem Mac. Put it here: ~/.config/karabiner

[
    // Wortweises Springen (Ctrl + Pfeil)
    {
        "key": "alt+left",
        "command": "-workbench.action.previousEditor"
    },
    {
        "key": "alt+right",
        "command": "-workbench.action.nextEditor"
    },
    {
        "key": "alt+left",
        "command": "cursorWordPartLeft",
        "when": "textInputFocus"
    },
    {
        "key": "alt+right",
        "command": "cursorWordPartRight",
        "when": "textInputFocus"
    },
    // Wortweises Markieren (Ctrl + Shift + Pfeil)
    {
        "key": "alt+shift+left",
        "command": "cursorWordPartLeftSelect",
        "when": "textInputFocus"
    },
    {
        "key": "alt+shift+right",
        "command": "cursorWordPartRightSelect",
        "when": "textInputFocus"
    }
]
